 <!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Malta Mediterranean</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Título Principal -->
    <header class="main-header">
        <h1>Malta Mediterranean</h1>
    </header>

    <!-- Seção de Cards Pequenos e Discretos -->
    <main class="container">
        <section class="cards-grid">
            
            <!-- Card 1: Turismo -->
            <a href="turismo.html" class="card-discreto">
                <div class="card-content">
                    <h2>Turismo</h2>
                    <p>Explore as cidades históricas e a rica cultura maltesa.</p>
                </div>
            </a>

            <!-- Card 2: Gastronomia e Arquitetura -->
            <a href="gastronomy.html" class="card-discreto">
                <div class="card-content">
                    <h2>Gastronomia & Arquitetura</h2>
                    <p>Descubra os sabores tradicionais e os edifícios de pedra calcária.</p>
                </div>
            </a>

            <!-- Card 3: Blue Lagoon -->
            <a href="bluelagoon.html" class="card-discreto">
                <div class="card-content">
                    <h2>Blue Lagoon</h2>
                    <p>Visite as águas cristalinas e paradisíacas da ilha de Comino.</p>
                </div>
            </a>

        </section>
    </main>

</body>
</html>


